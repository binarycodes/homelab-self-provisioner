[Unit]
Description=GitHub Ephemeral Runner %i
After=network-online.target
Wants=network-online.target

[Container]
ContainerName=gh-runner-%i
Image=docker.io/binarycodes/github-runner:latest
Pull=always
EnvironmentFile={{ application_root }}/{{ application_name }}/env
Volume={{ application_root }}/{{ application_name }}/app.private-key.pem:/etc/github-runner/app.private-key.pem:ro,Z
PodmanArgs=--rm

[Service]
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
LogLevelMax=info

# Hardening
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=full
ProtectKernelModules=yes
ProtectKernelLogs=yes
RestrictRealtime=yes

[Install]
WantedBy=multi-user.target
